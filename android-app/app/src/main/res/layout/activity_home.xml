<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="10dp"
    android:layout_marginRight="10dp"
    android:layout_marginLeft="10dp"
    tools:context=".HomeActivity">

    <Button
        android:id="@+id/profile_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/perfil"
        tools:layout_editor_absoluteX="310dp"
        tools:layout_editor_absoluteY="14dp"
    />

    <Button
        android:id="@+id/sheetsbutton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/acessar_o_sheets"
        android:layout_below="@id/profile_button"
    />


    <TextView
        android:id="@+id/temperaturatexto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/temperatura"
        android:text="@string/temperatura_atualizada"
        android:layout_centerHorizontal="true"
        android:textSize="20sp"
        />

    <TextView
        android:id="@+id/temperatura"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_centerHorizontal="true"
        android:textSize="40sp"
        />

    <TextView
        android:id="@+id/horariotexto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/temperatura"
        android:text="@string/hor_rio_da_atualiza_o"
        android:layout_centerHorizontal="true"
        android:textSize="20sp"
        />

    <TextView
        android:id="@+id/horario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/horariotexto"
        android:layout_centerHorizontal="true"
        android:textSize="40sp"
        />
<!--    <TextView-->
<!--        android:id="@+id/id"-->
<!--        android:layout_width="wrap_content"-->
<!--        android:layout_height="wrap_content"-->
<!--        android:layout_below="@id/horario"-->
<!--        android:layout_centerHorizontal="true"-->
<!--        android:textSize="30sp"-->
<!--        />-->
    <TextView
        android:id="@+id/temperaturaMaxtexto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/temperatura_maxima"
        android:layout_below="@id/sheetsbutton"
        android:layout_alignParentStart="true"
        android:layout_marginTop="15dp"
        android:textSize="15sp"
        />

    <TextView
        android:id="@+id/temperaturaMax"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/temperaturaMaxtexto"
        android:layout_alignStart="@id/temperaturaMaxtexto"
        android:layout_marginStart="60dp"
        android:textSize="20sp"
    />

    <TextView
        android:id="@+id/temperaturaMintexto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/temperatura_minima"
        android:layout_alignParentEnd="true"
        android:layout_alignBaseline="@id/temperaturaMaxtexto"
        android:textSize="15sp"
        />

    <TextView
        android:id="@+id/temperaturaMin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/temperaturaMintexto"
        android:layout_alignStart="@id/temperaturaMintexto"
        android:layout_marginStart="60dp"
        android:textSize="20sp"
        />
    <TextView
        android:id="@+id/temperaturaExttexto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/temperatura_externa"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:layout_below="@id/horario"
        android:textSize="15sp"
        />

    <TextView
        android:id="@+id/temperaturaExt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/temperaturaExttexto"
        android:layout_centerHorizontal="true"
        android:textSize="20sp"
        />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/imageView"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_alignParentTop="true"
        android:layout_alignRight="@id/temperaturaMintexto"
        app:srcCompat="@drawable/vertical_sigla_fundo_claro" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/imageView2"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_alignParentTop="true"
        android:layout_marginRight="90dp"
        android:layout_alignEnd="@id/temperaturaMintexto"
        app:srcCompat="@drawable/logo_pet_redondo"
        />

</RelativeLayout>